# ── Supabase (persistent chat history) ───────────────────────────────────────
# Get from: supabase.com → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...

# Ayla (survey automation): use bundled Chromium by default (recommended).
# If you set PLAYWRIGHT_CHROMIUM_CHANNEL globally, Chrome may open an empty "Incognito" tab;
# either unset that variable or force Chrome explicitly:
# PLAYWRIGHT_SURVEY_BROWSER=chrome

# ── Rex (Lead Scout) ──────────────────────────────────────────────────────────
APIFY_API_TOKEN=your_apify_api_token_here
# Fallback if Apify credits exhausted:
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# ── Max (Mailchimp Outreach) ───────────────────────────────────────────────────
MAILCHIMP_API_KEY=your_mailchimp_api_key_here
MAILCHIMP_SERVER_PREFIX=us1
MAILCHIMP_LIST_ID=your_default_audience_id_here
MAILCHIMP_FROM_NAME=Your Name or Company
MAILCHIMP_REPLY_TO=your@email.com

# ── Cal (Google Calendar) ──────────────────────────────────────────────────────
GOOGLE_CALENDAR_CLIENT_ID=your_google_client_id_here
GOOGLE_CALENDAR_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALENDAR_REFRESH_TOKEN=your_google_refresh_token_here
GOOGLE_CALENDAR_ACCESS_TOKEN=
GOOGLE_CALENDAR_ID=primary
OWNER_EMAIL=your@email.com

# ── Cal — SMTP for appointment notifications ───────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_gmail_app_password_here

CONTEXT7_API_KEY=your_api_key_here
CONTEXT7_API_URL=https://context7.com/api
OPENAI_API_KEY=your_api_key_here
GHL_API_KEY=your_api_key_here
GHL_LOCATION_ID=your_location_id_here
GHL_BASE_URL=https://services.leadconnectorhq.com
GHL_API_VERSION=2021-07-28
GHL_WEBHOOK_TREATMENT_BOOKED=your_webhook_url_here
GHL_WEBHOOK_TREATMENT_RESCHEDULED=your_webhook_url_here
GHL_WEBHOOK_PC_BOOKED=your_webhook_url_here
GHL_WEBHOOK_PC_RESCHEDULED=your_webhook_url_here